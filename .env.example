# ─── Telegram ───────────────────────────────────────────────────
# From @BotFather
TELEGRAM_BOT_TOKEN=
# Public https URL where the Mini App is served (ngrok in dev)
MINIAPP_URL=
BOT_USERNAME=

# ─── Backend ────────────────────────────────────────────────────
BACKEND_PORT=8787
BACKEND_PUBLIC_URL=http://localhost:8787

# ─── Gasless (stretch, post-July-8) ─────────────────────────────
PIMLICO_API_KEY=
