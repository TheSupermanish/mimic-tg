# ─── Chain (Base Sepolia testnet) ───────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
CHAIN_ID=84532

# Deployer / resolver key (testnet only — never a real-funds key)
DEPLOYER_PRIVATE_KEY=
RESOLVER_PRIVATE_KEY=

# Deployed contract addresses (filled by deploy script → shared/addresses.json)
MOCK_USDT_ADDRESS=
PREDICTION_MARKET_ADDRESS=

# ─── Football data oracle ───────────────────────────────────────
# Free key from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# ─── Telegram ───────────────────────────────────────────────────
# From @BotFather
TELEGRAM_BOT_TOKEN=
# Public https URL where the Mini App is served (ngrok in dev)
MINIAPP_URL=
BOT_USERNAME=

# ─── Backend ────────────────────────────────────────────────────
BACKEND_PORT=8787
BACKEND_PUBLIC_URL=http://localhost:8787

# ─── AI sidekick (bot chat) ─────────────────────────────────────
# Claude powers the football-chat bot. Get a key at console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Gasless (EIP-7702) — optional; set to enable no-gas UX ─────
# Pimlico API key (free testnet sponsorship): https://dashboard.pimlico.io
PIMLICO_API_KEY=
# EIP-7702 delegate (SimpleAccount). Default works on Base Sepolia.
DELEGATION_ADDRESS=0xe6Cae83BdE06E4c305530e199D7217f42808555B
# Optional Pimlico sponsorship policy id (not required on testnet)
PIMLICO_SPONSORSHIP_POLICY_ID=
